# eBay API credentials (placeholders)
EBAY_SANDBOX_CLIENT_ID=your_sandbox_client_id
EBAY_SANDBOX_CLIENT_SECRET=your_sandbox_client_secret
EBAY_PROD_CLIENT_ID=your_production_client_id
EBAY_PROD_CLIENT_SECRET=your_production_client_secret

# Choose: production or sandbox
EBAY_ENV=production

# Shipping estimation destination (placeholder)
EBAY_SHIP_TO_ZIP=00000
EBAY_SHIP_TO_COUNTRY=US

# Email notifications (placeholders)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=your_email@gmail.com
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
